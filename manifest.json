{
  "manifest_version": 3,
  "name": "D365 SpeedUp",
  "version": "1.1",
  "description": "Accelerate Dynamics 365 customization and development with smart tools and generators.",
  "permissions": ["activeTab", "scripting", "clipboardWrite", "storage", "sidePanel"],

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidepanel-empty.html"
  },

  "action": {
    "default_popup": "speedup.html",
    "default_title": "D365 SpeedUp"
  },
  "icons": {
    "16": "assets/icon16.png",
    "48": "assets/icon48.png",
    "128": "assets/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["libs/prism/*", "dist/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
